// Problem 3 -- while loop statement for loop n to 1
#include <iostream>
using namespace std;
int main()
{
    int i=1;
    int n;
    cin >> n;
    while (i<=n) {
        cout << i << "";
        i++;
    }

    return 0;
}

//Problem 4 -- while loop statement for loop 1 to n
#include <iostream>
using namespace std;
int main()
{
    int n;
    cin >> n;
    int i=n;
    while (i>=0) {
        cout << i << "  ";
        i--;
    }

    return 0;
}


