//Problem 1 -- Recursion
//give output for n for all possible cases formed using 0 & 1 for n places with no consecutive ones

#include <iostream>
using namespace std;

int consecutiveOnes(int number) {
    int n= number;
    //base condition
    if (n==0) {
        return 1;
    }
    if (n==1) {
        return 2;
    }
    if (n==2) {
        return 3;
    }
    //logic
    return consecutiveOnes(n-1)+consecutiveOnes(n-2);
}

int main()
{
    
cout << consecutiveOnes(10);
    return 0;
}



//Problem 2 -- Recursion
//Tiles Problem
//find all the possibilities for 4*n if 4*4 gives two possibilities 4*1 and 1*4
//no diagonal arrangement either vertically or horizontally         
#include <iostream>
using namespace std;

int countWays(int n) {

    // Base condition
    if (n < 0)
        return 0;

    if (n < 4)
        return 1;

    //logic
    return countWays(n - 1) + countWays(n - 4);
}

int main() {
    cout << countWays(4);

    return 0;
}


//Problem 3 -- Recursion
//HOUSE ROBBER 
//leetcode - 198
class Solution {
public:

int robFrom(vector<int>& nums, int index) {
    //base condition
    if(index >= nums.size()) {
        return 0;
    }
    //logic
    int include = nums[index] + robFrom(nums,index+2);
    int exclude = robFrom (nums,index +1);
 return max (include,exclude);
}

    int rob(vector<int>& nums) {
        return robFrom(nums,0);
    }
};
