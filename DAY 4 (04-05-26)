/ Problem 4 
//STAR PATTERN in mirror image of right angle traingle form
#include <iostream>
using namespace std;
int main()
{
    int n;
    cin >> n;
    //number of times or number of rows
    for (int i=1; i<=n; i++) { 
        //number of spaces
        for (int j=n-i; j>=1; j--) {
            cout << " " ;
        }
        //number of star
         for (int k=1; k<=i; k++) {
            cout << "*";
        }
        
        
        cout << endl;
    }
  return 0; }

    
//Problem 5 -- Rectangle star pattern
#include <iostream>
using namespace std;
int main()
{
    int row, col;
    cin >> row >> col;
    for (int i=1; i<=row; i++) { 
        for (int j=1; j<=col; j++) {
