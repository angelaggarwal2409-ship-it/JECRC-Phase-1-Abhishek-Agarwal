// Print  10 to 1 using a do-while loop

#include <iostream>
using namespace std;

int main() {
    int i = 10;
    do {
        cout << i << " ";
        i--;
    } while(i >= 1);
    return 0;
}




//Problem 7 -- factorial using for loop
#include <iostream>
using namespace std;
int main()
{
    int n;
    cin >> n;
    int fact = 1;
    
    for ( int i = n; i >= 1; i--) {
        fact = fact *i;
    }
    cout << fact;
    return 0;
}





