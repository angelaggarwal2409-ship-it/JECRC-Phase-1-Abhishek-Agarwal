//Polymorphism means one name but many forms
//same function behaves differently depending on the type of the object is called
//two Types 
//compile time polymmorphism -- function overloading -- static
//resolved at compile time
//function overloads -- same function name , but different Parameters 
//faster execution
//run time polymorphism -- function overriding -- dynamic_
//resolved at run time
//function runtime -- same function name , same parameters , but different class
//uses a virtual keyword in the base class 
//acheiving this through the concept of Inheritance

//Types of Polymorphism -- 2.1 
//Function overloading 

#include <iostream>
using namespace std;

class Math {
public:
    void add(int a , int b){
        cout << a + b <<"\n";
    }
public:
    void add(double a , double b){
        cout << a + b <<"\n";
    }
};

int main() {
    Math m;
    m.add(5,2);
    m.add(5,5,5);
    m.add(5.2, 2.2);
    
}

//Problem -- 2
//Types of Polymorphism -- 2.1 
// Function overriding
// Function overriding -- means redefining a parent class function in the child class with the same name and same arguments

#include <iostream>
using namespace std;

class Animal{
    public:
    virtual void sound() {
        cout << "Animal makes a sound";
    }
};

class Dog : public Animal {
    public:
    void sound() override {
        cout << "Dog makes a sound" <<"\n";
    }
};

class Cat : public Animal {
    public:
    void sound() {
        cout << "Cat makes a sound" <<"\n";
    }
};

int main() {
    Dog d;
    Cat c;
    d.sound();
    c.sound();
    
}

//Function overriding
//Example 
//We didn`t declared virtual and override

#include <iostream>
using namespace std;

class Parent{
public:
     void sum(int a , int b){
        cout << a + b << "parent";
    }
};

class child : public Parent{
public:
    void sum(int a , int b) {
        cout << a + b << "child";
    }
};
int main() {
    child c;
    c.sum(10 , 20); 
}

//Function overriding
//Example 
//We declared virtual and override

#include <iostream>
using namespace std;

class Parent{
public:
    virtual void sum(int a , int b){
        cout << a + b << "parent";
    }
};

class child : public Parent{
public:
    void sum(int a , int b) override{
        cout << a + b << "child";
    }
};
int main() {
    child c;
    c.sum(10 , 20); 
}
